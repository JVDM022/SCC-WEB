# Copy this file to .env and fill in your real Azure Function URLs.
# .env is already ignored by git in this project.

# Needed for website.py
DATABASE_URL=postgresql://username:password@hostname:5432/database_name
AZ_TELEMETRY_URL=https://your-function-app.azurewebsites.net/api/telemetry?code=your-function-key
AZ_COMMAND_URL=https://your-function-app.azurewebsites.net/api/command?code=your-function-key

# Broadcast export -> Azure Blob
# Optional: if omitted, the export reuses AZ_TELEMETRY_URL.
BROADCAST_ENDPOINT_URL=https://your-function-app.azurewebsites.net/api/broadcast?code=your-function-key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-storage-account-key;EndpointSuffix=core.windows.net
# Optional: defaults to documentation.
BROADCAST_BLOB_CONTAINER=documentation
BROADCAST_BLOB_PATH_PREFIX=broadcast

# Optional: Azure IoT Hub service-side rollout support for device twins and OTA jobs.
IOTHUB_CONNECTION_STRING=HostName=your-hub.azure-devices.net;SharedAccessKeyName=service;SharedAccessKey=your-service-key
IOTHUB_DEFAULT_DEVICE_ID=esp32-relay-01
IOTHUB_OTA_MAX_EXECUTION_SECONDS=3600

# Optional
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AZURE_TIMEOUT_SECONDS=5
BROADCAST_ENDPOINT_METHOD=GET
BROADCAST_ENDPOINT_HEADERS_JSON=
BROADCAST_ENDPOINT_PAYLOAD_JSON=
TELEMETRY_LOG_PATH=/absolute/path/to/system_status_temperature_log.csv
PORT=5000
FLASK_DEBUG=0
